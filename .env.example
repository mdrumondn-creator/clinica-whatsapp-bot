# Configurações do Banco de Dados (PostgreSQL)
POSTGRES_DB=clinica_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=senha_super_segura_do_banco

# Configurações do Redis
REDIS_PASSWORD=senha_super_segura_do_redis

# Configurações Evolution API
EVOLUTION_SERVER_URL=http://localhost:8080
EVOLUTION_API_KEY=apikey_secreta_evolution
WEBHOOK_GLOBAL_URL=http://clinica-bot:8000/webhook

# Configurações Chatwoot
CHATWOOT_FRONTEND_URL=http://localhost:3000

# =========================================================
# SEGURANÇA — OBRIGATÓRIO DEFINIR ANTES DO DEPLOY
# =========================================================

# JWT Secret: gere com: openssl rand -hex 32
# Sem este valor, a aplicação NÃO inicia.
JWT_SECRET=SUBSTITUA_POR_UM_SEGREDO_FORTE_openssl_rand_hex_32

# Bot WhatsApp
# true  = bot processa e responde mensagens
# false = modo silencioso (recebe mas não responde)
ALLOW_SEND=true

# DB (usado pelo Python — aponta para o container Docker interno)
DB_HOST=postgres
DB_NAME=clinica_db
DB_USER=postgres
DB_PASS=senha_super_segura_do_banco
