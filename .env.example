# =========================================================
# CLÍNICA WHATSAPP BOT — VARIÁVEIS DE AMBIENTE
# Copie este arquivo para .env e preencha os valores reais
# NUNCA versione o arquivo .env — adicione ao .gitignore
# =========================================================

# --- Banco de Dados PostgreSQL ---
DB_HOST=localhost
DB_NAME=clinica
DB_USER=postgres
DB_PASS=SUA_SENHA_AQUI

# --- Segurança JWT (gere um valor aleatório longo) ---
# Exemplo: python -c "import secrets; print(secrets.token_hex(48))"
JWT_SECRET=troque-por-um-segredo-longo-e-aleatorio

# --- Controle de envio do bot ---
# Defina como "true" somente em produção/quando o bot estiver pronto para enviar mensagens
ALLOW_SEND=false

# --- Endereço do servidor FastAPI (para o painel admin) ---
# Em produção, substitua por https://seu-dominio.com
API_BASE=http://localhost:8000
